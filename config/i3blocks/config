# i3blocks profile

[WIRELESS]
command=./wireless
interval=5
label=WIRELESS: 


[ETHERNET]
command=./ethernet
interval=5
label=ETHERNET: 


[BATTERY]
command=./battery
interval=5
label=BAT: 


[DISK]
command=./disk
interval=30
label=DISK: 


[LOAD]
command=./load
interval=2
label=LOAD: 


[MEMORY]
command=./memory
interval=3
label=MEM: 


[TIME]
command=date '+%Y-%m-%d %a %H:%M'
interval=1
label=


[VOLUME]
command=./volume
interval=1
signal=1
